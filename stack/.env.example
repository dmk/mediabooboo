# Reference env. Agent emits the user's .env with only the keys their enabled services need.

# --- stack ---
STACK_NAME=mystack                           # compose project + container-name prefix

# --- host ---
PUID=1000                                   # uid containers run as
PGID=1000                                   # gid containers run as
TZ=UTC                                      # IANA timezone, e.g. Europe/Kyiv
HOST_LAN_IP=192.168.1.10                    # host's LAN address; used by Plex advertise, AdGuard, etc.

# --- paths ---
LIBRARY_ROOT=/srv/media                     # parent of movies/, series/, music/, downloads/

# --- reverse proxy / LAN DNS ---
INTERNAL_TLD=internal                       # used for *.<tld> when reverse_proxy.mode = internal-tld

# --- pihole ---
# Web UI/API password. Set before starting pihole.
PIHOLE_PASSWORD=
PIHOLE_UPSTREAMS=1.1.1.1;9.9.9.9

# --- jellyfin ---
JELLYFIN_CACHE_SIZE=8g                      # tmpfs cap for /cache (transcoding scratch)
JELLYFIN_PUBLIC_URL=http://jellyfin.internal

# --- plex ---
# One-shot token from https://plex.tv/claim; clear after first --force-recreate.
PLEX_CLAIM=

# --- beszel ---
# SSH pubkey from the hub's "Add System" dialog.
BESZEL_KEY=

# --- flaresolverr ---
FLARESOLVERR_LOG_LEVEL=info

# --- tailscale (only if enabled) ---
# Tailscale auth key, e.g. tskey-auth-...
TAILSCALE_AUTHKEY=
